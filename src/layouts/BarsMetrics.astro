---
import TerminalBarsPart1 from "@/components/TerminalBarsPart-1.astro";
import TerminalBarsPart2 from "@/components/TerminalBarsPart-2.astro";
---

<section class="relative w-[90%] h-full">
    <div class="flex flex-col justify-between">
        <div
            aria-label="simulated-linux-terminal"
            class="flex flex-row z-20 p-10 absolute w-full left-0 h-full items-center justify-center lg:w-[40%]"
        >
            <TerminalBarsPart1 />
        </div>
        <div
            aria-label="simulated-linux-terminal "
            class="flex flex-row z-30 w-full h-full right-0 absolute items-center justify-center lg:w-[80%]"
        >
            <TerminalBarsPart2 />
        </div>
    </div>
</section>
