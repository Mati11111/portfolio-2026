---
import "@/styles/global.css";
import PresentationCard from "@/components/Presentation-card.astro";
import ProfileDescription from "@/layouts/ProfileDescription.astro";
import ExperienceMenu from "@/layouts/RangerMenu.astro";
import BarsMetrics from "@/layouts/BarsMetrics.astro";
import Footer from "@/components/Footer.astro";
import { createTranslator } from "@/i18n";
import SpeedInsights from '@vercel/speed-insights/astro';

const pathname = Astro.url.pathname;

const lang = pathname.startsWith("/en") ? "en" : "es";

const tl = createTranslator(lang);

---

<html lang={lang}>
    <head>
        <meta charset="utf-8" />
        <title>{tl("head.title")}</title>
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="canonical" href={tl("footer.github-link")} />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <!-- METADATA SOCIALS -->
        <meta property="og:title" content={tl("head.metaTitle")} />
        <meta property="og:description" content={tl("head.metaDescription")} />
        <meta property="og:type" content="website" />
        <meta name="description" content={tl("head.metaDescription")} />
        <SpeedInsights/>
    </head>
    <body class="flex-col content-between">
        <main class="flex flex-col gap-y-10 w-full">
            <section
                class="min-h-[95vh] bg-primary w-full flex flex-col items-center justify-center overflow-x-hidden"
            >
                <PresentationCard />
            </section>
            <section class="h-[50vh] flex flex-col items-center justify-center">
                <ProfileDescription />
            </section>
            <section
                class="-mt-20 h-[80vh] flex flex-col items-center justify-center lg:-mt-30"
            >
                <ExperienceMenu />
            </section>
            <section
                class="-mt-20 h-[60vh] flex flex-col items-center justify-center lg:-mt-20"
            >
                <BarsMetrics />
            </section>
        </main>
        <div class="h-50">
            <footer
                id="footer"
                class="h-full bg-primary w-full flex flex-col items-center justify-center gap-y-10
         translate-y-full opacity-0"
            >
                <Footer />
            </footer>
        </div>
    </body>
</html>
<script>
    const footer = document.getElementById("footer");
    const observer = new IntersectionObserver(
        ([entry]) => {
            if (!footer) return;
            if (entry.isIntersecting) {
                footer.classList.remove("opacity-0");
                footer.classList.add("animate-footerContainerApear");
            }
        },
        { threshold: 0.1 },
    );
    if (footer) observer.observe(footer);
</script>
<script is:inline>
    if (
        localStorage.theme === "dark" ||
        (!("theme" in localStorage) &&
            window.matchMedia("(prefers-color-scheme: dark)").matches)
    ) {
        document.documentElement.classList.add("dark");
    } else {
        document.documentElement.classList.remove("dark");
    }
</script>
