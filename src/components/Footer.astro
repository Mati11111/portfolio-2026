---
import { useI18n } from "@ariaskit/astro-i18n";
const { t, lang } = useI18n(Astro);
const currentYear = new Date().getFullYear();
---

<section class="flex flex-col">
    <div
        aria-label="social-media-links"
        class="flex flex-row items-center justify-center gap-x-3 text-2xl tracking-wider"
    >
        <a
            href={t("footer.github-link")}
            target="_blank"
            rel="noopener noreferrer"
            class="link group flex flex-col justify-center items-center"
        >
            <span class="text-secondary">{t("footer.github")}</span>
            <hr
                class="border border-secondary w-0 group-hover:w-[50%] transition-all duration-300"
            />
        </a>

        <a
            href={t("footer.linkedin-link")}
            target="_blank"
            rel="noopener noreferrer"
            class="link group flex flex-col justify-center items-center"
        >
            <span class="text-secondary">{t("footer.linkedin")}</span>
            <hr
                class="border border-secondary w-0 group-hover:w-[50%] transition-all duration-300"
            />
        </a>

        <div
            class="link group flex flex-col justify-center items-center cursor-pointer"
            onclick="navigator.clipboard.writeText('matias.chaparro.mail@gmail.com')"
            aria-label="Copy email to clipboard"
        >
            <span class="text-secondary">{t("footer.email")}</span>
            <hr
                class="border border-secondary w-0 group-hover:w-[50%] transition-all duration-300"
            />
        </div>
    </div>
</section>

<div class="flex flex-col justify-center items-center">
    <h1 id="presentation-card" class="text-secondary">
        {t("footer.sign")}
    </h1>
    <p id="copyright" class="text-secondary">
        &copy; {currentYear}
    </p>
</div>

<script>
    const linkElements = document.querySelectorAll(".link");
    linkElements.forEach((el) => {
        const hr = el.querySelector("hr");
        el.addEventListener("click", () => {
            if (hr) {
                hr.style.width = "100%";
                setTimeout(() => {
                    hr.style.width = "";
                }, 200);
            }
        });
    });
</script>
